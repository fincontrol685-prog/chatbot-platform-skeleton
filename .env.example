# ============================================================
# CHATBOT PLATFORM - PRODUCTION ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and update the values for your environment
# IMPORTANT: Never commit .env file with real secrets to version control
# ============================================================

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=chatbot_prod
DB_USERNAME=chatbot_user
DB_PASSWORD=your_secure_database_password_here_change_me_NOW
MYSQL_ROOT_PASSWORD=your_secure_root_password_here_change_me_NOW

# ============================================================
# SECURITY - JWT
# ============================================================
# Generate a strong JWT secret:
# openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production_use_at_least_32_chars
JWT_EXPIRATION_MS=3600000

# ============================================================
# SECURITY - SSL/HTTPS
# ============================================================
SSL_ENABLED=false
SSL_KEY_STORE=/etc/ssl/keystore.p12
SSL_KEY_STORE_PASSWORD=your_keystore_password

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://chatbot.company.com,https://www.company.com

# ============================================================
# SERVER CONFIGURATION
# ============================================================
SERVER_PORT=8080
BACKEND_PORT=8080
NGINX_PORT=80
NGINX_SSL_PORT=443

# ============================================================
# PROMETHEUS & MONITORING
# ============================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=your_secure_grafana_password_here_change_me_NOW

# ============================================================
# LOGGING
# ============================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BR_CHATBOT=INFO

# ============================================================
# JAVA JVM CONFIGURATION
# ============================================================
# Memory allocation: adjust based on your server capacity
# Default: 512MB max, 256MB min
# For production: consider 2GB-4GB depending on load
JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ============================================================
# SPRING PROFILE
# ============================================================
SPRING_PROFILES_ACTIVE=prod

# ============================================================
# IMPORTANT SECURITY NOTES
# ============================================================
# 1. Change ALL passwords and secrets before deploying to production
# 2. Use strong, random values for JWT_SECRET (minimum 32 characters)
# 3. Store this file securely - consider using Docker secrets or HashiCorp Vault
# 4. Never commit secrets to version control
# 5. Rotate secrets regularly
# 6. Use environment-specific .env files
# 7. Restrict file permissions: chmod 600 .env
# 8. Use HTTPS in production (set SSL_ENABLED=true)

